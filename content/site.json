{
  "_comment": "Flux de pages du BBS Oric. Modifiable a chaud. Une page a un titre, du texte (lines) et/ou des choix (entries). Avec entries = ecran interactif, sinon ecran de contenu. Une entree navigue (target: page ou __quit__/__back__/__home__) OU lance un applet (applet + next). Une page peut aussi porter un form (action login/register, fields key/label/secret, next, fail, retries) = ecran de saisie declaratif. Applets: login, register, guest. Couleurs ink: black red green yellow blue magenta cyan white.",
  "start": "accueil",
  "pages": {
    "accueil": {
      "title": "BIENVENUE",
      "entries": [
        {
          "key": "1",
          "label": "Se connecter",
          "target": "login"
        },
        {
          "key": "2",
          "label": "Creer un compte",
          "target": "register"
        },
        {
          "key": "3",
          "label": "Entrer en invite",
          "applet": "guest",
          "next": "main"
        },
        {
          "key": "Q",
          "label": "Quitter",
          "target": "__quit__"
        }
      ]
    },
    "login": {
      "title": "CONNEXION",
      "form": {
        "action": "login",
        "next": "main",
        "fail": "echec",
        "fields": [
          {
            "key": "login",
            "label": "Pseudo"
          },
          {
            "key": "password",
            "label": "Mot de passe",
            "secret": true
          }
        ]
      }
    },
    "register": {
      "title": "CREATION DE COMPTE",
      "form": {
        "action": "register",
        "next": "main",
        "fail": "echec",
        "fields": [
          {
            "key": "login",
            "label": "Pseudo desire"
          },
          {
            "key": "password",
            "label": "Mot de passe",
            "secret": true
          },
          {
            "key": "confirm",
            "label": "Confirmer",
            "secret": true
          }
        ]
      }
    },
    "echec": {
      "title": "ECHEC",
      "lines": [
        {
          "text": "Operation impossible apres plusieurs essais.",
          "ink": "red"
        },
        {
          "text": ""
        },
        {
          "text": "Reessayez depuis l'accueil.",
          "ink": "yellow"
        }
      ]
    },
    "main": {
      "title": "MENU PRINCIPAL",
      "entries": [
        {
          "key": "1",
          "label": "Informations systeme",
          "target": "info"
        },
        {
          "key": "2",
          "label": "A propos du BBS",
          "target": "about"
        },
        {
          "key": "3",
          "label": "Livre d'or",
          "target": "guestbook"
        },
        {
          "key": "4",
          "label": "Services",
          "target": "services"
        },
        {
          "key": "5",
          "label": "Fichiers",
          "target": "fichiers"
        },
        {
          "key": "Q",
          "label": "Quitter",
          "target": "__quit__"
        }
      ]
    },
    "fichiers": {
      "title": "FICHIERS",
      "entries": [
        {
          "key": "1",
          "label": "Telecharger",
          "applet": "download",
          "next": "fichiers"
        },
        {
          "key": "2",
          "label": "Televerser",
          "applet": "upload",
          "next": "fichiers"
        },
        {
          "key": "R",
          "label": "Retour",
          "target": "__back__"
        }
      ]
    },
    "info": {
      "title": "INFORMATIONS SYSTEME",
      "lines": [
        {
          "text": " Serveur  - BBS Oric (Go)"
